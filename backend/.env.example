# ============================================================
# Environment Variables Reference - MLM Admin
# ============================================================
# Copy relevant vars to Render dashboard or .env for local dev
# ============================================================

# --- Application ---
# APP_ENV=production
# APP_PORT=8080        # Render auto-injects PORT, no need to set
# FRONTEND_URL=https://mlm-frontend.onrender.com

# --- Database (Render PostgreSQL) ---
# DATABASE_URL=postgresql://user:pass@host:port/mlm_admin
# DB_SSL_MODE=require

# --- Database (local Docker, individual fields) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mlm_admin
# DB_USER=admin
# DB_PASSWORD=your_password
# DB_SSL_MODE=disable

# --- Redis ---
# REDIS_URL=redis://host:6379

# --- JWT ---
# JWT_SECRET=your_32+_char_secret_here
# JWT_ACCESS_EXPIRY=15m
# JWT_REFRESH_EXPIRY=7d

# --- CORS ---
# CORS_ALLOWED_ORIGINS=https://mlm-frontend.onrender.com,http://localhost:3000

# --- Frontend (set NEXT_PUBLIC_API_URL during Docker build) ---
# NEXT_PUBLIC_API_URL=https://mlm-backend.onrender.com/api/v1
